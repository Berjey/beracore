# BERACORE — İletişim formu SMTP ayarları
# Bu dosyayı .env.local olarak kopyalayın ve gerçek değerlerle doldurun.
# .env.local gitignore'da — commit'lenmez.

# Sunucu host ve port
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# Port 465 ise true, 587/STARTTLS ise false (boş bırakılırsa port'a göre otomatik)
SMTP_SECURE=false

# SMTP kimlik bilgileri
SMTP_USER=info@beracore.com
SMTP_PASS=your-smtp-password-or-app-password

# Gönderen (MAIL FROM) — kimi sağlayıcı SMTP_USER ile aynı olmasını bekler
SMTP_FROM="BERACORE <info@beracore.com>"

# Bildirimlerin düşeceği adres (çoklu: virgülle)
SMTP_TO=info@beracore.com
